# =============================================================================
# Auktivo - Environment Variables Template
# =============================================================================
# Copy to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Local dev:  point to your local Supabase Studio instance
# Production: swap in your Supabase Cloud project values on Vercel
#
# NEVER commit .env.local to version control!
# =============================================================================

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Auktivo

# --- Supabase ----------------------------------------------------------------
# Local:      http://127.0.0.1:54321
# Production: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct DB connection (local only, not needed on Vercel)
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Schema: auktivo_dev (local) | auktivo_test (preview) | auktivo_prod (production)
# Must be exposed in Supabase: Project Settings → API → Exposed schemas
NEXT_PUBLIC_SUPABASE_DB_SCHEMA=auktivo_dev

# --- KI: MAX -----------------------------------------------------------------
# Ollama laeuft auf Port 11434 (direkt). LiteLLM-Proxy (Port 4000) muss separat gestartet werden.
# Ollama direkt:      http://<LAN-IP>:11434/v1
# LiteLLM (wenn aktiv): http://<LAN-IP>:4000/v1
MAX_API_BASE_URL=http://192.168.178.75:11434/v1
MAX_API_KEY=sk-max-litellm-2026

# Schnelle Erstanalyse (sofort, inline)
# qwen3.6:35b ist das beste verfuegbare Modell (30s, hohe Qualitaet)
MAX_MODEL_FAST=qwen3.6:35b

# Tiefenanalyse (Hintergrund, Button-getriggert)
# Installation: ollama pull qwen3.5:122b (auf dem MAX-Server ausfuehren)
# HINWEIS: Modellwechsel zwischen FAST und DEEP kostet ~40s VRAM-Reload falls kein separates GPU-Slot.
MAX_MODEL_DEEP=qwen3.5:122b

# --- Google Maps (optional) --------------------------------------------------
# Wenn gesetzt: zeigt Google Street View auf der Objekt-Detailseite
# Ohne Key: kostenlose OpenStreetMap-Karte als Fallback
# Nur serverseitig (kein NEXT_PUBLIC_) - Key erscheint NICHT im Client-Bundle
# ACHTUNG: Key im Google Cloud Console auf deine Domain einschraenken!
GOOGLE_MAPS_STATIC_API_KEY=

# --- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRO_PRICE_ID=price_...

# --- Resend (E-Mail) ---------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@auktivo.de

# --- Web Push (VAPID) --------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@auktivo.de

# --- Cron Security -----------------------------------------------------------
CRON_SECRET=

# --- Crawler -----------------------------------------------------------------
# Auf Vercel (Pro: maxDuration=300s) muss das Enrichment uebersprungen werden,
# da Detail-Seiten + PDF-Downloads ~19 Min. dauern und die Funktion sonst gekillt wird.
# Lokal und auf dedizierten Servern weglassen oder auf "false" setzen.
# Vercel: CRAWLER_SKIP_ENRICHMENT=true
# Lokal:  CRAWLER_SKIP_ENRICHMENT=false (oder weglassen)
CRAWLER_SKIP_ENRICHMENT=false
