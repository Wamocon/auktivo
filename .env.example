# =============================================================================
# Auktivo - Environment Variables Template
# =============================================================================
# Copy to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Local dev:  point to your local Supabase Studio instance
# Production: swap in your Supabase Cloud project values on Vercel
#
# NEVER commit .env.local to version control!
# =============================================================================

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Auktivo

# --- Supabase ----------------------------------------------------------------
# Local:      http://127.0.0.1:54321
# Production: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct DB connection (local only, not needed on Vercel)
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Schema: auktivo_dev (local) | auktivo_test (preview) | auktivo_prod (production)
# Must be exposed in Supabase: Project Settings → API → Exposed schemas
NEXT_PUBLIC_SUPABASE_DB_SCHEMA=auktivo_dev

# --- KI: MAX -----------------------------------------------------------------
MAX_API_BASE_URL=
MAX_API_KEY=
MAX_MODEL=max-default

# --- Google Maps (optional) --------------------------------------------------
# Wenn gesetzt: zeigt Google Street View auf der Objekt-Detailseite
# Ohne Key: kostenlose OpenStreetMap-Karte als Fallback
# Nur serverseitig (kein NEXT_PUBLIC_) - Key erscheint NICHT im Client-Bundle
# ACHTUNG: Key im Google Cloud Console auf deine Domain einschraenken!
GOOGLE_MAPS_STATIC_API_KEY=

# --- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRO_PRICE_ID=price_...

# --- Resend (E-Mail) ---------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@auktivo.de

# --- Web Push (VAPID) --------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@auktivo.de

# --- Cron Security -----------------------------------------------------------
CRON_SECRET=
