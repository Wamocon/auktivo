#!/usr/bin/env bash
# =============================================================================
# Pre-commit Hook - Secret Scanner
# =============================================================================
# Blocks any commit that contains hard-coded secrets, API keys, tokens, or
# credentials before they ever leave your machine.
#
# INSTALL (run once per repo after cloning):
#   bash hooks/install.sh
#
# BYPASS (emergency only - never for secret-containing commits):
#   git commit --no-verify -m "your message"
#
# ADD EXCEPTIONS:
#   Add a comment  # notsecret  on the same line in your source file, OR
#   add the filename to the ALLOWED_FILES list near the top of this script.
# =============================================================================

set -euo pipefail

# ─── Configuration ────────────────────────────────────────────────────────────

# Files that are always safe to commit even if they match patterns below.
ALLOWED_FILES=(
  "hooks/pre-commit"
  ".github/workflows/deploy.yml"
  ".github/workflows/pr-pipeline.yml"
  "docs/workflow-guide.md"
  "HOWTO.md"
  ".env.example"
  "supabase/migrations/20260514000000_initial_schema.sql"
  "supabase/migrations/20260516000000_app_settings.sql"
)

# ─── Colours ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
RESET='\033[0m'

# ─── Helpers ──────────────────────────────────────────────────────────────────
found=0

flag_match() {
  local file="$1" line_no="$2" line="$3" reason="$4"

  # Skip lines with the inline exception marker
  echo "$line" | grep -q 'notsecret' && return 0

  if [[ "$found" -eq 0 ]]; then
    echo ""
    echo -e "${RED}${BOLD}[pre-commit] BLOCKED - potential secrets detected${RESET}"
    echo -e "${YELLOW}─────────────────────────────────────────────────────────────${RESET}"
  fi
  echo -e "  ${RED}✖${RESET} ${BOLD}${file}${RESET}:${line_no}"
  echo -e "    Reason : ${YELLOW}${reason}${RESET}"
  echo -e "    Content: ${line:0:120}"
  echo ""
  found=1
}

is_allowed() {
  local file="$1"
  for allowed in "${ALLOWED_FILES[@]}"; do
    [[ "$file" == "$allowed" ]] && return 0
  done
  return 1
}

# ─── Get staged files ─────────────────────────────────────────────────────────
staged_files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [[ -z "$staged_files" ]]; then
  exit 0
fi

# ─── Block .env files ────────────────────────────────────────────────────────
while IFS= read -r file; do
  [[ -z "$file" ]] && continue
  is_allowed "$file" && continue

  basename=$(basename "$file")
  if [[ "$basename" == ".env" || "$basename" == ".env.local" || \
        "$basename" == ".env.production" || "$basename" == ".env.development" ]]; then
    if [[ "$found" -eq 0 ]]; then
      echo ""
      echo -e "${RED}${BOLD}[pre-commit] BLOCKED - .env file staged for commit${RESET}"
      echo -e "${YELLOW}─────────────────────────────────────────────────────────────${RESET}"
    fi
    echo -e "  ${RED}✖${RESET} ${BOLD}${file}${RESET}"
    echo -e "    Reason : ${YELLOW}.env files must never be committed. Add it to .gitignore.${RESET}"
    echo ""
    found=1
  fi
done <<< "$staged_files"

# ─── Scan file content for secret patterns ───────────────────────────────────
# Windows-optimised: one grep call per pattern per file instead of per line.
# This avoids the O(lines*patterns) process-fork penalty that freezes Git on Windows.

scan_pattern() {
  # Usage: scan_pattern <file> <tmp_file> <ERE-pattern> <reason> [i]
  # The optional 5th argument "i" enables case-insensitive matching.
  local file="$1" tmp_file="$2" pattern="$3" reason="$4" ci="${5:-}"
  while IFS= read -r match; do
    local line_no content trimmed
    line_no="${match%%:*}"
    content="${match#*:}"
    # Skip inline exception marker (pure bash, no subprocess)
    [[ "$content" == *notsecret* ]] && continue
    # Skip comment-only lines
    trimmed="${content#"${content%%[! ]*}"}"
    [[ "$trimmed" == \#* ]] && continue
    [[ "$trimmed" == //* ]] && continue
    [[ "$trimmed" == \** ]] && continue
    flag_match "$file" "$line_no" "$content" "$reason"
  done < <(grep -n"${ci}"E "$pattern" "$tmp_file" 2>/dev/null || true)
}

while IFS= read -r file; do
  [[ -z "$file" ]] && continue
  is_allowed "$file" && continue

  # Skip binary files using git metadata only (more reliable on Windows)
  if git diff --cached --numstat -- "$file" | grep -qE '^-\s+-\s+'; then
    continue
  fi

  tmp_content_file=$(mktemp)
  git show ":$file" > "$tmp_content_file" 2>/dev/null || true

  # ── AWS ──────────────────────────────────────────────────────────────────
  scan_pattern "$file" "$tmp_content_file" \
    'AKIA[0-9A-Z]{16}' "AWS Access Key ID (AKIA...)"
  scan_pattern "$file" "$tmp_content_file" \
    '(aws_secret_access_key|aws_secret)[[:space:]]*[=:][[:space:]]*["'"'"']?[A-Za-z0-9/+=]{40}' \
    "AWS Secret Access Key" "i"

  # ── GitHub tokens ────────────────────────────────────────────────────────
  scan_pattern "$file" "$tmp_content_file" \
    'gh[psoura]_[A-Za-z0-9]{36,}' "GitHub Personal/Service Access Token"
  scan_pattern "$file" "$tmp_content_file" \
    'github_pat_[A-Za-z0-9_]{20,}' "GitHub Fine-grained PAT"

  # ── Vercel ───────────────────────────────────────────────────────────────
  scan_pattern "$file" "$tmp_content_file" \
    '(vercel_token|VERCEL_TOKEN)[[:space:]]*[=:][[:space:]]*["'"'"']?[A-Za-z0-9]{20,}' \
    "Vercel token hard-coded in file" "i"

  # ── Generic API keys / secrets ────────────────────────────────────────────
  scan_pattern "$file" "$tmp_content_file" \
    '(api[_-]?key|apikey)[[:space:]]*[=:][[:space:]]*["'"'"']?[A-Za-z0-9_-]{20,}' \
    "Generic API key" "i"
  scan_pattern "$file" "$tmp_content_file" \
    '(secret[_-]?key|secret_token|client_secret)[[:space:]]*[=:][[:space:]]*["'"'"']?[A-Za-z0-9_-]{12,}' \
    "Hard-coded secret/client secret" "i"
  scan_pattern "$file" "$tmp_content_file" \
    '(access_token|ACCESS_TOKEN)[[:space:]]*[=:][[:space:]]*["'"'"']?[A-Za-z0-9_.+-]{20,}' \
    "Hard-coded access token" "i"
  scan_pattern "$file" "$tmp_content_file" \
    '(password|passwd|db_password|db_pass)[[:space:]]*[=:][[:space:]]*["'"'"']?[^ "'"'"']{8,}' \
    "Hard-coded password" "i"

  # ── Private keys ──────────────────────────────────────────────────────────
  scan_pattern "$file" "$tmp_content_file" \
    '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY' "Private key (PEM format)"

  # ── Connection strings ────────────────────────────────────────────────────
  scan_pattern "$file" "$tmp_content_file" \
    '(postgres|mysql|mongodb|redis)://[^:]+:[^@]{3,}@' \
    "Database connection string with embedded password"

  # ── JWT tokens ────────────────────────────────────────────────────────────
  scan_pattern "$file" "$tmp_content_file" \
    'eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}' "JWT token"

  # ── Supabase ──────────────────────────────────────────────────────────────
  scan_pattern "$file" "$tmp_content_file" \
    '(service_role|supabase_service_role)[[:space:]]*[=:][[:space:]]*["'"'"']?ey[A-Za-z0-9_-]{20,}' \
    "Supabase service role key" "i"
  scan_pattern "$file" "$tmp_content_file" \
    'sb_publishable_[A-Za-z0-9_-]{20,}' \
    "Supabase anon/publishable key hard-coded in file"

  rm -f "$tmp_content_file"

done <<< "$staged_files"

# ─── Result ───────────────────────────────────────────────────────────────────
if [[ "$found" -ne 0 ]]; then
  echo -e "${YELLOW}─────────────────────────────────────────────────────────────${RESET}"
  echo -e "${BOLD}Wie beheben / How to fix:${RESET}"
  echo -e "  1. Entferne / Remove the secret from the file."
  echo -e "  2. Speichere es in / Store it in your ${BOLD}.env.local${RESET} (already in .gitignore)."
  echo -e "  3. Nutze / Use GitHub Actions secrets for CI/CD values."
  echo ""
  echo -e "${BOLD}Falsch-Positiv / False positive${RESET} (e.g. example value in docs):"
  echo -e "  Add  ${YELLOW}# notsecret${RESET}  at the end of that line."
  echo ""
  echo -e "${RED}Commit blockiert / Commit blocked. Fix the issues above and try again.${RESET}"
  echo ""
  exit 1
fi

echo -e "${GREEN}[pre-commit] Keine Geheimnisse gefunden / No secrets detected.${RESET}"
exit 0
